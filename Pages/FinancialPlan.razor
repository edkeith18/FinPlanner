@page "/financial-plan"

@using FinPlanner.Data

@inject Portfolio portfolio

<PageTitle>Financial Plan</PageTitle>

<h1>Financial Plan</h1>

@if (portfolio.CurrentAge > portfolio.LifeExpectancy)
{
    <p class="text-muted mb-3">No plan rows to display because Current age is greater than Life expectancy.</p>
}
else
{
    <table class="table table-bordered table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th scope="col">Year</th>
                <th scope="col">Expenses</th>
                <th scope="col">Balance</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in FinancialPlanCalculator.BuildPlanRows(portfolio))
            {
                <tr>
                    <td>@row.Year</td>
                    <td>@row.Expenses.ToString("C")</td>
                    <td>@row.Balance.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}
