@page "/accounts"

@using FinPlanner.Data
@inject Portfolio portfolio
@inject NavigationManager Nav

<PageTitle>Accounts</PageTitle>

<h1>Accounts</h1>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Balance</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var account in portfolio.Accounts)
        {
            <tr>
                <!-- Read-only name -->
                <td>
                    <NavLink href="@($"account/{account.Name}")">@account.Name</NavLink>
                </td>

                <!-- Editable balance -->
                <td @onclick="() => StartEditing(account)">
                    @if (IsEditing(account))
                    {
                        <InputNumber @bind-Value="account.Balance"
                                     class="form-control"
                                     @onblur="() => StopEditing(account)" />
                    }
                    else
                    {
                        <span>@account.Balance.ToString("C")</span>
                    }
                </td>

                <!-- Delete button -->
                <td>
                    <button class="btn btn-link text-danger"
                            @onclick="() => DeleteAccount(account)">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>

            </tr>
        }
    </tbody>
</table>

<button class="btn btn-success mb-3" @onclick="CreateNewAccount">
    + New Account
</button>

@code {
    private readonly Dictionary<Account, bool> editing = new();

    private void CreateNewAccount()
    {
        Nav.NavigateTo("account/new");
    }

    private void DeleteAccount(Account account)
    {
        portfolio.Accounts.Remove(account);
    }

    private bool IsEditing(Account account)
    {
        return editing.TryGetValue(account, out var value) && value;
    }

    private void StartEditing(Account account)
    {
        editing[account] = true;
    }

    private void StopEditing(Account account)
    {
        editing[account] = false;
    }
}
