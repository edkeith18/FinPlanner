                break;
        }
    }

    private decimal GetParameterValue(ParameterField parameter)
    {
        return parameter switch
        {
            ParameterField.CurrentAge => portfolio.CurrentAge,
            ParameterField.LifeExpectancy => portfolio.LifeExpectancy,
            ParameterField.AnnualExpenses => portfolio.AnnualExpenses,
            ParameterField.SecuritiesAnnualInterestRate => portfolio.SecuritiesAnnualInterestRate,
            ParameterField.AnnualInflationRate => portfolio.AnnualInflationRate,
            ParameterField.BondsAnnualRateOfReturn => portfolio.BondsAnnualRateOfReturn,
            _ => 0m
        };
    }

    private void SetParameterValue(ParameterField parameter, decimal value)
    {
        switch (parameter)
        {
            case ParameterField.CurrentAge:
                portfolio.CurrentAge = decimal.ToInt32(decimal.Truncate(value));
                break;
            case ParameterField.LifeExpectancy:
                portfolio.LifeExpectancy = decimal.ToInt32(decimal.Truncate(value));
                break;
            case ParameterField.AnnualExpenses:
                portfolio.AnnualExpenses = value;
                break;
            case ParameterField.SecuritiesAnnualInterestRate:
                portfolio.SecuritiesAnnualInterestRate = value;
                break;
            case ParameterField.AnnualInflationRate:
                portfolio.AnnualInflationRate = value;
                break;
            case ParameterField.BondsAnnualRateOfReturn:
                portfolio.BondsAnnualRateOfReturn = value;
                break;
        }
    }

    private void UpdateDirtyState()
    {
        isDirty = SerializePortfolio() != baselineSnapshot;
        portfolio.NotifyStateChanged();
    }

    private string SerializePortfolio(bool pretty = false)
    {
        var options = CreateProfileJsonOptions();
        options.WriteIndented = pretty;
        return JsonSerializer.Serialize(portfolio, options);
    }

    private static JsonSerializerOptions CreateProfileJsonOptions()
    {
        var options = new JsonSerializerOptions();
        options.Converters.Add(new JsonStringEnumConverter());
        return options;
    }

    private bool IsSectionBusy(AddItemType itemType)
    {
        if (activeAddType == itemType)
        {
            return true;
        }

        return itemType switch
        {
            AddItemType.Account => editingRows.OfType<Account>().Any()
                || editingNameRows.OfType<Account>().Any()
                || editingTypeRows.Any()
                || editingHoldingsRows.Any(),
            AddItemType.Income => editingRows.OfType<IncomeItem>().Any()
                || editingNameRows.OfType<IncomeItem>().Any(),
            AddItemType.Expense => editingRows.OfType<ExpenseItem>().Any()
                || editingNameRows.OfType<ExpenseItem>().Any(),
            _ => false
        };
    }

    private bool CanStartSectionEdit(object item)
    {
        var itemType = GetSectionType(item);
        if (itemType is null)
        {
            return false;
        }

        if (activeAddType == itemType)
        {
            return false;
        }

        var activeRow = GetActiveEditRow(itemType.Value);
        return activeRow is null || ReferenceEquals(activeRow, item);
    }

    private AddItemType? GetSectionType(object item)
    {
        return item switch
        {
            Account => AddItemType.Account,
            IncomeItem => AddItemType.Income,
            ExpenseItem => AddItemType.Expense,
            _ => null
        };
    }

    private object? GetActiveEditRow(AddItemType itemType)
    {
        return itemType switch
        {
            AddItemType.Account => editingRows.OfType<Account>().Cast<object>().FirstOrDefault()
                ?? editingNameRows.OfType<Account>().Cast<object>().FirstOrDefault()
                ?? editingTypeRows.Cast<object>().FirstOrDefault()
                ?? editingHoldingsRows.Cast<object>().FirstOrDefault(),
            AddItemType.Income => editingRows.OfType<IncomeItem>().Cast<object>().FirstOrDefault()
                ?? editingNameRows.OfType<IncomeItem>().Cast<object>().FirstOrDefault(),
            AddItemType.Expense => editingRows.OfType<ExpenseItem>().Cast<object>().FirstOrDefault()
                ?? editingNameRows.OfType<ExpenseItem>().Cast<object>().FirstOrDefault(),
            _ => null
        };
    }

    private bool IsAccountRowEditing(Account account)
    {
        return editingRows.Contains(account)
            || editingNameRows.Contains(account)
            || editingTypeRows.Contains(account)
            || editingHoldingsRows.Contains(account);
    }

    private bool IsIncomeRowEditing(IncomeItem income)
    {
        return editingRows.Contains(income) || editingNameRows.Contains(income);
    }

    private bool IsExpenseRowEditing(ExpenseItem expense)
    {
        return editingRows.Contains(expense) || editingNameRows.Contains(expense);
    }

    private void CommitItemEdit(object item)
    {
        StopEditingName(item, commitChanges: true);
        StopEditing(item, commitChanges: true);
    }

    private void CancelItemEdit(object item)
    {
        StopEditingName(item, commitChanges: false);
        StopEditing(item, commitChanges: false);
    }

    private void CommitAccountEdit(Account account)
    {
        StopEditingName(account, commitChanges: true);
        StopEditingType(account, commitChanges: true);
        StopEditingHoldings(account, commitChanges: true);
        StopEditing(account, commitChanges: true);
    }

    private void CancelAccountEdit(Account account)
    {
        StopEditingName(account, commitChanges: false);
        StopEditingType(account, commitChanges: false);
        StopEditingHoldings(account, commitChanges: false);
        StopEditing(account, commitChanges: false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!pendingFocusNewRow || activeAddType is null)
        {
            return;
        }

        pendingFocusNewRow = false;
        var inputId = GetAddNameInputId(activeAddType.Value);
        var rowId = GetAddRowId(activeAddType.Value);
        await JS.InvokeVoidAsync(
            "eval",
            $"(function(){{var row=document.getElementById('{rowId}');if(row){{row.scrollIntoView({{block:'nearest'}});}}var input=document.getElementById('{inputId}');if(input){{input.focus();}}}})();");
    }

    private enum AddItemType
    {
        Account,
        Income,
        Expense
    }

    private enum ParameterField
    {
        CurrentAge,
        LifeExpectancy,
        AnnualExpenses,
        SecuritiesAnnualInterestRate,
        AnnualInflationRate,
        BondsAnnualRateOfReturn
    }
}
