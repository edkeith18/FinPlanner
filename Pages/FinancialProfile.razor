@page "/financial-profile"

@using System.Text.Json
@using FinPlanner.Data
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web

@inject Portfolio portfolio
@inject IJSRuntime JS

<PageTitle>Financial Profile</PageTitle>

<h1>Financial Profile</h1>

<div class="d-flex gap-2 align-items-center mb-3">
    <label for="profileFileInput" class="btn btn-secondary mb-0">Load profile</label>
    <InputFile id="profileFileInput" class="d-none" OnChange="LoadFile" MaxFileSize="5000000" />
    <button class="btn btn-primary" @onclick="Save" disabled="@(!isDirty)">Download profile</button>
</div>

<div class="financial-profile-layout">
    <div class="financial-profile-panel">
        <h5>Parameters</h5>
        <table class="table table-borderless align-middle table-sm compact-table mb-0">
            <tbody>
                <tr>
                    <td class="item-name">Securities annual interest rate</td>
                    <td class="item-value">
                        @if (editingInterestRate)
                        {
                            <InputNumber @bind-Value="portfolio.SecuritiesAnnualInterestRate"
                                         class="form-control form-control-sm"
                                         @onblur="OnInterestRateBlur"
                                         @onkeydown="OnInterestRateKeyDown"
                                         @ref="interestRateInputRef" />
                        }
                        else
                        {
                            <span role="button" tabindex="0" class="clickable-value" @onclick="StartEditingInterestRate">@($"{portfolio.SecuritiesAnnualInterestRate}%")</span>
                        }
                    </td>
                </tr>
            </tbody>
        </table>

        <hr />

        <h5>Accounts</h5>
        <table class="table table-borderless align-middle table-sm compact-table mb-0">
            <tbody>
                @foreach (var account in portfolio.Accounts.OrderBy(a => a.Name, StringComparer.CurrentCultureIgnoreCase))
                {
                    <tr>
                        <td class="item-name">@account.Name</td>
                        <td class="item-value">
                            @if (IsEditing(account))
                            {
                                <InputNumber @bind-Value="account.Balance"
                                             class="form-control form-control-sm"
                                             @onblur="() => StopEditing(account, commitChanges: true)"
                                             @onkeydown="(e) => OnItemValueKeyDown(account, e)" />
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-value" @onclick="() => StartEditing(account)">@account.Balance.ToString("C")</span>
                            }
                        </td>
                        <td class="item-actions">
                            <button class="btn btn-link text-danger p-0" @onclick="() => DeleteAccount(account)" aria-label="Delete @account.Name">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <button class="btn btn-success btn-sm mt-2" @onclick="() => StartAdd(AddItemType.Account)">Add Account</button>

        <hr />

        <h5>Income</h5>
        <table class="table table-borderless align-middle table-sm compact-table mb-0">
            <tbody>
                @foreach (var income in portfolio.Income.OrderBy(i => i.Name, StringComparer.CurrentCultureIgnoreCase))
                {
                    <tr>
                        <td class="item-name">@income.Name</td>
                        <td class="item-value">
                            @if (IsEditing(income))
                            {
                                <InputNumber @bind-Value="income.Amount"
                                             class="form-control form-control-sm"
                                             @onblur="() => StopEditing(income, commitChanges: true)"
                                             @onkeydown="(e) => OnItemValueKeyDown(income, e)" />
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-value" @onclick="() => StartEditing(income)">@income.Amount.ToString("C")</span>
                            }
                        </td>
                        <td class="item-actions">
                            <button class="btn btn-link text-danger p-0" @onclick="() => DeleteIncome(income)" aria-label="Delete @income.Name">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <button class="btn btn-success btn-sm mt-2" @onclick="() => StartAdd(AddItemType.Income)">Add Income</button>

        <hr />

        <h5>Expenses</h5>
        <table class="table table-borderless align-middle table-sm compact-table mb-0">
            <tbody>
                @foreach (var expense in portfolio.Expenses.OrderBy(e => e.Name, StringComparer.CurrentCultureIgnoreCase))
                {
                    <tr>
                        <td class="item-name">@expense.Name</td>
                        <td class="item-value">
                            @if (IsEditing(expense))
                            {
                                <InputNumber @bind-Value="expense.Amount"
                                             class="form-control form-control-sm"
                                             @onblur="() => StopEditing(expense, commitChanges: true)"
                                             @onkeydown="(e) => OnItemValueKeyDown(expense, e)" />
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-value" @onclick="() => StartEditing(expense)">@expense.Amount.ToString("C")</span>
                            }
                        </td>
                        <td class="item-actions">
                            <button class="btn btn-link text-danger p-0" @onclick="() => DeleteExpense(expense)" aria-label="Delete @expense.Name">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <button class="btn btn-success btn-sm mt-2" @onclick="() => StartAdd(AddItemType.Expense)">Add Expense</button>

        @if (activeAddType is not null)
        {
            <div class="card mt-3 p-3">
                <h6 class="mb-3">Add @activeAddType</h6>
                <div class="mb-2">
                    <label class="form-label mb-1">Name</label>
                    <InputText @bind-Value="newItemName" class="form-control form-control-sm" />
                </div>
                <div class="mb-2">
                    <label class="form-label mb-1">@GetValueLabel(activeAddType.Value)</label>
                    <InputNumber @bind-Value="newItemValue" class="form-control form-control-sm" />
                </div>
                <div class="d-flex gap-2 mt-2">
                    <button class="btn btn-primary btn-sm" @onclick="SaveNewItem">Save</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelAdd">Cancel</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private readonly Dictionary<object, decimal> originalValues = new();
    private readonly HashSet<object> editingRows = new();
    private bool editingInterestRate;
    private decimal originalInterestRate;
    private bool isDirty;
    private string baselineSnapshot = string.Empty;
    private ElementReference interestRateInputRef;

    private AddItemType? activeAddType;
    private string newItemName = string.Empty;
    private decimal newItemValue;

    protected override void OnInitialized()
    {
        baselineSnapshot = SerializePortfolio();
    }

    private async Task LoadFile(InputFileChangeEventArgs e)
    {
        var file = e.File;

        using var stream = file.OpenReadStream(maxAllowedSize: 5_000_000);
        using var reader = new StreamReader(stream, System.Text.Encoding.UTF8, detectEncodingFromByteOrderMarks: true);

        string json = await reader.ReadToEndAsync();

        var data = JsonSerializer.Deserialize<Portfolio>(json);

        if (data is null)
            return;

        portfolio.Accounts = data.Accounts ?? new List<Account>();
        portfolio.Income = data.Income ?? new List<IncomeItem>();
        portfolio.Expenses = data.Expenses ?? new List<ExpenseItem>();
        portfolio.Year = data.Year;
        portfolio.SecuritiesAnnualInterestRate = data.SecuritiesAnnualInterestRate;

        editingRows.Clear();
        originalValues.Clear();
        editingInterestRate = false;
        activeAddType = null;

        baselineSnapshot = SerializePortfolio();
        UpdateDirtyState();
    }

    private async Task Save()
    {
        var json = SerializePortfolio(pretty: true);
        await SaveFileAsync("FinPlanner.json", json);
        baselineSnapshot = SerializePortfolio();
        UpdateDirtyState();
    }

    private async Task SaveFileAsync(string filename, string json)
    {
        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(json));
        var url = $"data:application/json;base64,{base64}";

        await JS.InvokeVoidAsync("eval", $@"
            var a = document.createElement('a');
            a.href = '{url}';
            a.download = '{filename}';
            a.click();
        ");
    }

    private bool IsEditing(object item)
    {
        return editingRows.Contains(item);
    }

    private void StartEditing(object item)
    {
        if (editingRows.Contains(item))
        {
            return;
        }

        originalValues[item] = GetItemValue(item);
        editingRows.Add(item);
    }

    private void StopEditing(object item, bool commitChanges)
    {
        if (!editingRows.Contains(item))
        {
            return;
        }

        editingRows.Remove(item);

        if (!commitChanges && originalValues.TryGetValue(item, out var originalValue))
        {
            SetItemValue(item, originalValue);
        }

        originalValues.Remove(item);
        UpdateDirtyState();
    }

    private async Task StartEditingInterestRate()
    {
        if (editingInterestRate)
        {
            return;
        }

        originalInterestRate = portfolio.SecuritiesAnnualInterestRate;
        editingInterestRate = true;
        await Task.Yield();
        await interestRateInputRef.FocusAsync();
    }

    private void StopEditingInterestRate(bool commitChanges)
    {
        if (!editingInterestRate)
        {
            return;
        }

        if (!commitChanges)
        {
            portfolio.SecuritiesAnnualInterestRate = originalInterestRate;
        }

        editingInterestRate = false;
        UpdateDirtyState();
    }

    private void OnInterestRateBlur(FocusEventArgs _)
    {
        StopEditingInterestRate(commitChanges: true);
    }

    private void OnInterestRateKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            StopEditingInterestRate(commitChanges: true);
        }
        else if (e.Key == "Escape")
        {
            StopEditingInterestRate(commitChanges: false);
        }
    }

    private void OnItemValueKeyDown(object item, KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            StopEditing(item, commitChanges: true);
        }
        else if (e.Key == "Escape")
        {
            StopEditing(item, commitChanges: false);
        }
    }

    private async Task DeleteAccount(Account account)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Delete account '{account.Name}'?"))
        {
            portfolio.Accounts.Remove(account);
            editingRows.Remove(account);
            originalValues.Remove(account);
            UpdateDirtyState();
        }
    }

    private async Task DeleteIncome(IncomeItem income)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Delete income '{income.Name}'?"))
        {
            portfolio.Income.Remove(income);
            editingRows.Remove(income);
            originalValues.Remove(income);
            UpdateDirtyState();
        }
    }

    private async Task DeleteExpense(ExpenseItem expense)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Delete expense '{expense.Name}'?"))
        {
            portfolio.Expenses.Remove(expense);
            editingRows.Remove(expense);
            originalValues.Remove(expense);
            UpdateDirtyState();
        }
    }

    private void StartAdd(AddItemType itemType)
    {
        activeAddType = itemType;
        newItemName = string.Empty;
        newItemValue = 0;
    }

    private void CancelAdd()
    {
        activeAddType = null;
        newItemName = string.Empty;
        newItemValue = 0;
    }

    private void SaveNewItem()
    {
        if (activeAddType is null)
        {
            return;
        }

        var name = newItemName.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            return;
        }

        switch (activeAddType)
        {
            case AddItemType.Account:
                portfolio.AddAccount(name, newItemValue);
                break;
            case AddItemType.Income:
                portfolio.AddIncome(name, newItemValue);
                break;
            case AddItemType.Expense:
                portfolio.AddExpense(name, newItemValue);
                break;
        }

        CancelAdd();
        UpdateDirtyState();
    }

    private string GetValueLabel(AddItemType itemType)
    {
        return itemType == AddItemType.Account ? "Balance" : "Amount";
    }

    private decimal GetItemValue(object item)
    {
        return item switch
        {
            Account account => account.Balance,
            IncomeItem income => income.Amount,
            ExpenseItem expense => expense.Amount,
            _ => 0m
        };
    }

    private void SetItemValue(object item, decimal value)
    {
        switch (item)
        {
            case Account account:
                account.Balance = value;
                break;
            case IncomeItem income:
                income.Amount = value;
                break;
            case ExpenseItem expense:
                expense.Amount = value;
                break;
        }
    }

    private void UpdateDirtyState()
    {
        isDirty = SerializePortfolio() != baselineSnapshot;
    }

    private string SerializePortfolio(bool pretty = false)
    {
        return JsonSerializer.Serialize(portfolio, new JsonSerializerOptions { WriteIndented = pretty });
    }

    private enum AddItemType
    {
        Account,
        Income,
        Expense
    }
}
