    private void StartAdd(AddItemType itemType)
    {
        if (activeAddType == itemType || IsSectionBusy(itemType))
        {
            return;
        }

        activeAddType = itemType;
        newItemName = string.Empty;
        newItemValue = 0;
        newAccountType = AccountType.Brokerage;
        newAccountHoldings = AccountHoldings.Equities;
        pendingFocusNewRow = true;
    }

    private void CancelAdd()
    {
        activeAddType = null;
        newItemName = string.Empty;
        newItemValue = 0;
        newAccountType = AccountType.Brokerage;
        newAccountHoldings = AccountHoldings.Equities;
        pendingFocusNewRow = false;
    }

    private void SaveNewItem()
    {
        if (activeAddType is null)
        {
            return;
        }

        var name = newItemName.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            return;
        }

        switch (activeAddType)
        {
            case AddItemType.Account:
                portfolio.AddAccount(name, newItemValue, newAccountType, newAccountHoldings);
                break;
            case AddItemType.Income:
                portfolio.AddIncome(name, newItemValue);
                break;
            case AddItemType.Expense:
                portfolio.AddExpense(name, newItemValue);
                break;
        }

        CancelAdd();
        UpdateDirtyState();
    }

    private void OnAddInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SaveNewItem();
        }
        else if (e.Key == "Escape")
        {
            CancelAdd();
        }
    }

    private string GetAddRowId(AddItemType itemType)
    {
        return $"add-row-{itemType.ToString().ToLowerInvariant()}";
    }

    private string GetAddNameInputId(AddItemType itemType)
    {
        return $"add-name-{itemType.ToString().ToLowerInvariant()}";
    }

    private decimal GetItemValue(object item)
    {
        return item switch
        {
            Account account => account.Balance,
            IncomeItem income => income.Amount,
            ExpenseItem expense => expense.Amount,
            _ => 0m
        };
    }

    private void SetItemValue(object item, decimal value)
    {
        switch (item)
        {
            case Account account:
                account.Balance = value;
                break;
            case IncomeItem income:
                income.Amount = value;
                break;
            case ExpenseItem expense:
                expense.Amount = value;
                break;
        }
    }

    private string GetItemName(object item)
    {
        return item switch
        {
            Account account => account.Name,
            IncomeItem income => income.Name,
            ExpenseItem expense => expense.Name,
            _ => string.Empty
        };
    }

    private void SetItemName(object item, string value)
    {
        switch (item)
        {
            case Account account:
                account.Name = value;
                break;
            case IncomeItem income:
                income.Name = value;
                break;
            case ExpenseItem expense:
