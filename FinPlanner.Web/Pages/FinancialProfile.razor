        ["pattern"] = "[0-9]*",
        ["onkeydown"] = "return ['Backspace','Delete','ArrowLeft','ArrowRight','Tab','Home','End','Enter','Escape'].includes(event.key) || /^[0-9]$/.test(event.key);"
    };
    private readonly HashSet<object> editingRows = new();
    private readonly HashSet<object> editingNameRows = new();
    private readonly HashSet<Account> editingTypeRows = new();
    private readonly HashSet<Account> editingHoldingsRows = new();
    private readonly HashSet<Expense> editingExpenseStartAgeRows = new();
    private readonly HashSet<Expense> editingExpenseEndAgeRows = new();
    private readonly HashSet<Expense> editingExpenseAnnualRateRows = new();
    private readonly HashSet<Transfer> editingTransferStartAgeRows = new();
    private readonly HashSet<Transfer> editingTransferEndAgeRows = new();
    private readonly HashSet<Transfer> editingTransferAnnualRateRows = new();
    private readonly HashSet<Transfer> editingTransferFromAccountRows = new();
    private readonly HashSet<Transfer> editingTransferToAccountRows = new();
    private readonly Dictionary<ParameterField, decimal> originalParameterValues = new();
    private readonly HashSet<ParameterField> editingParameters = new();
    private bool isDirty;
    private string baselineSnapshot = string.Empty;

    private AddItemType? activeAddType;
    private string newItemName = string.Empty;
    private decimal newItemValue;
    private AccountType newAccountType = AccountType.Brokerage;
    private AccountHoldings newAccountHoldings = AccountHoldings.Equities;
