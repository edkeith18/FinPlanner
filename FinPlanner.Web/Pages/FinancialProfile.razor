    private bool newExpenseUseInflationValue = true;
    private string newTransferFromAccountName = string.Empty;
    private string newTransferToAccountName = string.Empty;
    private bool pendingFocusNewRow;
    private static readonly JsonSerializerOptions scenarioJsonOptions = CreateScenarioJsonOptions();

    private string SaveScenarioButtonClass => isDirty ? "btn btn-danger" : "btn btn-secondary";

    protected override void OnInitialized()
    {
        baselineSnapshot = Serializescenario();
    }

    private async Task LoadFile(InputFileChangeEventArgs e)
    {
        var file = e.File;

        using var stream = file.OpenReadStream(maxAllowedSize: 5_000_000);
        using var reader = new StreamReader(stream, System.Text.Encoding.UTF8, detectEncodingFromByteOrderMarks: true);

        string json = await reader.ReadToEndAsync();

        var data = JsonSerializer.Deserialize<Scenario>(json, scenarioJsonOptions);

        if (data is null)
            return;

        ApplyLegacyExpenseInflationDefaults(data, json);
        ApplyLegacyTransferInflationDefaults(data, json);

        scenario.Accounts = data.Accounts ?? new List<Account>();
        scenario.Income = data.Income ?? new List<IncomeItem>();
        scenario.Expenses = data.Expenses ?? new List<Expense>();
        scenario.Transfers = data.Transfers ?? new List<Transfer>();
        scenario.Year = data.Year;
        scenario.SecuritiesAnnualInterestRate = data.SecuritiesAnnualInterestRate;
        scenario.AnnualInflationRate = data.AnnualInflationRate;
        scenario.CurrentAge = data.CurrentAge;
        scenario.LifeExpectancy = data.LifeExpectancy;
        scenario.AnnualExpenses = data.AnnualExpenses;
        scenario.BondsAnnualRateOfReturn = data.BondsAnnualRateOfReturn;
        NormalizeLoadedExpenses(scenario.Expenses);
        NormalizeLoadedTransfers(scenario.Transfers);

        editingRows.Clear();
        editingNameRows.Clear();
        editingTypeRows.Clear();
        editingHoldingsRows.Clear();
        editingExpenseStartAgeRows.Clear();
        editingExpenseEndAgeRows.Clear();
        editingExpenseAnnualRateRows.Clear();
        originalValues.Clear();
        originalNames.Clear();
        originalAccountTypes.Clear();
        originalAccountHoldings.Clear();
        originalExpenseStartAges.Clear();
        originalExpenseEndAges.Clear();
        originalExpenseAnnualRates.Clear();
        originalExpenseUseInflationValues.Clear();
        ClearTransferEditState();
        editingParameters.Clear();
        originalParameterValues.Clear();
        activeAddType = null;

        baselineSnapshot = Serializescenario();
        UpdateDirtyState();
    }


    private static void ApplyLegacyExpenseInflationDefaults(Scenario data, string json)
    {
        if (data.Expenses is null || data.Expenses.Count == 0)
        {
            return;
        }

        using var document = JsonDocument.Parse(json);

        if (!document.RootElement.TryGetProperty(nameof(Scenario.Expenses), out var expensesElement)
            || expensesElement.ValueKind != JsonValueKind.Array)
        {
            return;
        }

        var index = 0;
        foreach (var expenseElement in expensesElement.EnumerateArray())
        {
            if (index >= data.Expenses.Count)
            {
                break;
            }

            var expense = data.Expenses[index];
            if (!expenseElement.TryGetProperty(nameof(Expense.UseInflationValue), out _))
            {
                expense.UseInflationValue = !HasCustomLegacyExpenseRate(expenseElement, data.AnnualInflationRate);
            }

            index++;
        }
    }


    private static void ApplyLegacyTransferInflationDefaults(Scenario data, string json)
    {
        if (data.Transfers is null || data.Transfers.Count == 0)
        {
            return;
        }

        using var document = JsonDocument.Parse(json);

        if (!document.RootElement.TryGetProperty(nameof(scenario.Transfers), out var transfersElement)
            || transfersElement.ValueKind != JsonValueKind.Array)
        {
            return;
        }

        var index = 0;
        foreach (var transferElement in transfersElement.EnumerateArray())
        {
            if (index >= data.Transfers.Count)
            {
                break;
            }

            var transfer = data.Transfers[index];
            if (!transferElement.TryGetProperty(nameof(Transfer.UseInflationValue), out _))
            {
                transfer.UseInflationValue = !HasCustomAnnualRate(transferElement, data.AnnualInflationRate);
            }

            index++;
        }
    }

    private static bool HasCustomLegacyExpenseRate(JsonElement expenseElement, decimal annualInflationRate)
    {
        return HasCustomAnnualRate(expenseElement, annualInflationRate);
    }

    private static bool HasCustomAnnualRate(JsonElement itemElement, decimal annualInflationRate)
    {
        if (itemElement.TryGetProperty(nameof(Expense.AnnualRateOfIncrease), out var annualRateElement)
            && annualRateElement.TryGetDecimal(out var annualRate))
        {
            return annualRate != annualInflationRate;
        }

        if (itemElement.TryGetProperty("annualRateOfIncrease", out var legacyAnnualRateElement)
            && legacyAnnualRateElement.TryGetDecimal(out var legacyAnnualRate))
        {
            return legacyAnnualRate != annualInflationRate;
        }

        return false;
    }

    private async Task Save()
    {
        var json = Serializescenario(pretty: true);
        await SaveFileAsync("FinPlanner.json", json);
        baselineSnapshot = Serializescenario();
        UpdateDirtyState();
    }

    private async Task SaveFileAsync(string filename, string json)
    {
        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(json));
        var url = $"data:application/json;base64,{base64}";

        await JS.InvokeVoidAsync("eval", $@"
            var a = document.createElement('a');
            a.href = '{url}';
            a.download = '{filename}';
            a.click();
        ");
    }

    private bool IsEditing(object item)
    {
        return editingRows.Contains(item);
    }

    private bool IsEditingName(object item)
    {
        return editingNameRows.Contains(item);
    }

    private bool IsEditingType(Account account)
    {
        return editingTypeRows.Contains(account);
    }

    private bool IsEditingHoldings(Account account)
    {
        return editingHoldingsRows.Contains(account);
    }

    private void StartEditing(object item)
    {
        if (editingRows.Contains(item))
        {
            return;
        }

        if (!CanStartSectionEdit(item))
        {
            return;
        }

        originalValues[item] = GetItemValue(item);
        editingRows.Add(item);
    }

    private void StopEditing(object item, bool commitChanges)
    {
        if (!editingRows.Contains(item))
        {
            return;
        }

        editingRows.Remove(item);

        if (!commitChanges && originalValues.TryGetValue(item, out var originalValue))
        {
            SetItemValue(item, originalValue);
        }

        originalValues.Remove(item);
        UpdateDirtyState();
    }

    private void StartEditingName(object item)
    {
        if (editingNameRows.Contains(item))
        {
            return;
        }

        if (!CanStartSectionEdit(item))
        {
            return;
        }

        originalNames[item] = GetItemName(item);
        editingNameRows.Add(item);
    }

    private void StopEditingName(object item, bool commitChanges)
    {
        if (!editingNameRows.Contains(item))
        {
            return;
        }

        editingNameRows.Remove(item);

        if (!commitChanges && originalNames.TryGetValue(item, out var originalName))
        {
            SetItemName(item, originalName);
        }
        else
        {
            var updatedName = GetItemName(item).Trim();
            if (string.IsNullOrWhiteSpace(updatedName) && originalNames.TryGetValue(item, out var fallbackName))
            {
                SetItemName(item, fallbackName);
            }
            else
            {
                SetItemName(item, updatedName);
            }
        }

        originalNames.Remove(item);
        UpdateDirtyState();
    }

    private bool IsEditingParameter(ParameterField parameter)
    {
        return editingParameters.Contains(parameter);
    }

    private void StartEditingParameter(ParameterField parameter)
    {
        if (editingParameters.Contains(parameter))
        {
            return;
        }

        if (HasActiveEditOrAdd)
        {
            return;
        }

        originalParameterValues[parameter] = GetParameterValue(parameter);
        editingParameters.Add(parameter);
    }

    private void CommitParameterEdit(ParameterField parameter)
    {
        StopEditingParameter(parameter, commitChanges: true);
    }

    private void CancelParameterEdit(ParameterField parameter)
    {
        StopEditingParameter(parameter, commitChanges: false);
    }

    private void StopEditingParameter(ParameterField parameter, bool commitChanges)
    {
        if (!editingParameters.Contains(parameter))
        {
            return;
        }

        editingParameters.Remove(parameter);

        if (!commitChanges && originalParameterValues.TryGetValue(parameter, out var originalValue))
        {
            SetParameterValue(parameter, originalValue);
        }

        originalParameterValues.Remove(parameter);

        if (commitChanges && parameter == ParameterField.AnnualInflationRate)
        {
            ApplyInflationRateToLinkedItems();
        }

        UpdateDirtyState();
    }

    private void OnParameterKeyDown(ParameterField parameter, KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            CommitParameterEdit(parameter);
        }
        else if (e.Key == "Escape")
        {
            CancelParameterEdit(parameter);
        }
    }

