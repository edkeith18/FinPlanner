    private void NormalizeLoadedExpenses(IEnumerable<Expense> expenses)
    {
        var currentCalendarYear = DateTime.Now.Year;

        foreach (var expense in expenses)
        {
            if (expense.AgeStart >= 1900)
            {
                expense.AgeStart = scenario.CurrentAge + expense.AgeStart - currentCalendarYear;
            }

            if (expense.AgeEnd >= 1900)
            {
                expense.AgeEnd = scenario.CurrentAge + expense.AgeEnd - currentCalendarYear;
            }

            if (expense.UseInflationValue)
            {
                expense.AnnualRateOfIncrease = scenario.AnnualInflationRate;
            }
        }
    }

    private void NormalizeLoadedTransfers(IEnumerable<Transfer> transfers)
    {
        var currentCalendarYear = DateTime.Now.Year;

        foreach (var transfer in transfers)
        {
            if (transfer.AgeStart >= 1900)
            {
                transfer.AgeStart = scenario.CurrentAge + transfer.AgeStart - currentCalendarYear;
            }

            if (transfer.AgeEnd >= 1900)
            {
                transfer.AgeEnd = scenario.CurrentAge + transfer.AgeEnd - currentCalendarYear;
            }

            EnsureTransferAccountSelectionIsValid(transfer);

            if (transfer.UseInflationValue)
            {
                transfer.AnnualRateOfIncrease = scenario.AnnualInflationRate;
            }
        }
    }


    private void ApplyInflationRateToLinkedItems()
    {
        foreach (var expense in scenario.Expenses.Where(expense => expense.UseInflationValue))
