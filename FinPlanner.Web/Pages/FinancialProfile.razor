        {
            expense.AgeStart = originalStartAge;
        }

        if (editingExpenseEndAgeRows.Remove(expense) && !commitChanges && originalExpenseEndAges.TryGetValue(expense, out var originalEndAge))
        {
            expense.AgeEnd = originalEndAge;
        }

        if (editingExpenseAnnualRateRows.Remove(expense))
        {
            if (!commitChanges)
            {
                if (originalExpenseAnnualRates.TryGetValue(expense, out var originalAnnualRate))
                {
                    expense.AnnualRateOfIncrease = originalAnnualRate;
                }

                if (originalExpenseUseInflationValues.TryGetValue(expense, out var originalUseInflationValue))
                {
                    expense.UseInflationValue = originalUseInflationValue;
                }
            }
            else if (expense.UseInflationValue)
            {
                expense.AnnualRateOfIncrease = scenario.AnnualInflationRate;
            }
        }

        originalExpenseStartAges.Remove(expense);
        originalExpenseEndAges.Remove(expense);
        originalExpenseAnnualRates.Remove(expense);
        originalExpenseUseInflationValues.Remove(expense);
        UpdateDirtyState();
