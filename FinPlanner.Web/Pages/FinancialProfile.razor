    private async Task DeleteAccount(Account account)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Delete account '{account.Name}'?"))
        {
            scenario.Accounts.Remove(account);
            editingRows.Remove(account);
            editingNameRows.Remove(account);
            editingTypeRows.Remove(account);
            editingHoldingsRows.Remove(account);
            originalValues.Remove(account);
            originalNames.Remove(account);
            originalAccountTypes.Remove(account);
            originalAccountHoldings.Remove(account);
