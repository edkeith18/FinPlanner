            expense.AnnualRateOfIncrease = scenario.AnnualInflationRate;
        }

        foreach (var transfer in scenario.Transfers.Where(transfer => transfer.UseInflationValue))
        {
            transfer.AnnualRateOfIncrease = scenario.AnnualInflationRate;
        }
    }

