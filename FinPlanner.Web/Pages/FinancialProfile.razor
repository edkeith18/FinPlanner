    private void StartAdd(AddItemType itemType)
    {
        if (activeAddType == itemType || HasActiveEditOrAdd)
        {
            return;
        }

        activeAddType = itemType;
        newItemName = string.Empty;
        newItemValue = 0;
        newAccountType = AccountType.Brokerage;
        newAccountHoldings = AccountHoldings.Equities;
        SetNewExpenseDefaults();
        SetNewTransferDefaults();
        pendingFocusNewRow = true;
    }

    private void CancelAdd()
    {
        activeAddType = null;
        newItemName = string.Empty;
        newItemValue = 0;
        newAccountType = AccountType.Brokerage;
        newAccountHoldings = AccountHoldings.Equities;
        newExpenseStartAge = 0;
        newExpenseEndAge = 0;
        newExpenseAnnualRateOfIncrease = 0;
        newExpenseUseInflationValue = true;
        newTransferFromAccountName = string.Empty;
        newTransferToAccountName = string.Empty;
        pendingFocusNewRow = false;
    }

    private void SaveNewItem()
    {
        if (activeAddType is null)
        {
            return;
        }

        var name = newItemName.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            return;
        }

        switch (activeAddType)
        {
            case AddItemType.Account:
                scenario.AddAccount(name, newItemValue, newAccountType, newAccountHoldings);
                break;
            case AddItemType.Income:
                scenario.AddIncome(name, newItemValue);
                break;
            case AddItemType.Expense:
                scenario.AddExpense(name, newItemValue, newExpenseStartAge, newExpenseEndAge, newExpenseAnnualRateOfIncrease, newExpenseUseInflationValue);
                break;
            case AddItemType.Transfer:
                if (!CanAddTransfer)
                {
                    return;
                }
                scenario.AddTransfer(name, newItemValue, newExpenseStartAge, newExpenseEndAge, newTransferFromAccountName, newTransferToAccountName, newExpenseAnnualRateOfIncrease, newExpenseUseInflationValue);
                break;
        }

        CancelAdd();
        UpdateDirtyState();
    }

    private void OnAddInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SaveNewItem();
        }
        else if (e.Key == "Escape")
        {
            CancelAdd();
        }
    }

