@page "/"
@page "/financial-scenario"

@using System.Text.Json
@using System.Text.Json.Serialization
@using FinPlanner.Engine
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web

@inject Scenario scenario
@inject IJSRuntime JS

<PageTitle>Financial Scenario</PageTitle>

<h1>Financial Scenario</h1>

<div class="d-flex gap-2 align-items-center mb-3">
    <label for="scenarioFileInput" class="btn btn-secondary mb-0">Load scenario</label>
    <InputFile id="scenarioFileInput" class="d-none" OnChange="LoadFile" MaxFileSize="5000000" />
    <button class="@SaveScenarioButtonClass" @onclick="Save" disabled="@(!isDirty)">Save scenario (download)</button>
</div>

<div class="financial-scenario-layout">
    <div class="@FinancialScenarioPanelClass">
        <h5>Parameters</h5>
        <h6 class="parameter-subgroup-heading">Personal</h6>
        <table class="table table-borderless align-middle table-sm compact-table mb-0">
            <tbody>
                <tr class="@(IsEditingParameter(ParameterField.CurrentAge) ? "edit-mode-row" : null)">
                    <td class="item-name">Current age</td>
                    <td class="item-value">
                        @if (IsEditingParameter(ParameterField.CurrentAge))
                        {
                            <InputNumber @bind-Value="scenario.CurrentAge"
                                         class="form-control form-control-sm"
                                         tabindex="1"
                                         @attributes="wholeNumberInputAttributes"
                                         @onkeydown="(e) => OnParameterKeyDown(ParameterField.CurrentAge, e)" />
                        }
                        else
                        {
                            <span role="button" tabindex="1" class="clickable-value" @onclick="() => StartEditingParameter(ParameterField.CurrentAge)">@scenario.CurrentAge</span>
                        }
                    </td>
                    <td class="item-actions">
                        @if (IsEditingParameter(ParameterField.CurrentAge))
                        {
                            <button class="btn btn-link text-success p-0 me-2"
                                    @onclick="() => CommitParameterEdit(ParameterField.CurrentAge)"
                                    aria-label="Commit current age edit">
                                <i class="bi bi-check-circle"></i>
                            </button>
                            <button class="btn btn-link text-secondary p-0"
                                    @onclick="() => CancelParameterEdit(ParameterField.CurrentAge)"
                                    aria-label="Cancel current age edit">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        }
                    </td>
                </tr>
                <tr class="@(IsEditingParameter(ParameterField.LifeExpectancy) ? "edit-mode-row" : null)">
                    <td class="item-name">Life expectancy</td>
                    <td class="item-value">
                        @if (IsEditingParameter(ParameterField.LifeExpectancy))
                        {
                            <InputNumber @bind-Value="scenario.LifeExpectancy"
                                         class="form-control form-control-sm"
                                         tabindex="2"
                                         @attributes="wholeNumberInputAttributes"
                                         @onkeydown="(e) => OnParameterKeyDown(ParameterField.LifeExpectancy, e)" />
                        }
                        else
                        {
                            <span role="button" tabindex="2" class="clickable-value" @onclick="() => StartEditingParameter(ParameterField.LifeExpectancy)">@scenario.LifeExpectancy</span>
                        }
                    </td>
                    <td class="item-actions">
                        @if (IsEditingParameter(ParameterField.LifeExpectancy))
                        {
                            <button class="btn btn-link text-success p-0 me-2"
                                    @onclick="() => CommitParameterEdit(ParameterField.LifeExpectancy)"
                                    aria-label="Commit life expectancy edit">
                                <i class="bi bi-check-circle"></i>
                            </button>
                            <button class="btn btn-link text-secondary p-0"
                                    @onclick="() => CancelParameterEdit(ParameterField.LifeExpectancy)"
                                    aria-label="Cancel life expectancy edit">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        }
                    </td>
                </tr>
                <tr class="@(IsEditingParameter(ParameterField.AnnualExpenses) ? "edit-mode-row" : null)">
                    <td class="item-name">Annual expenses</td>
                    <td class="item-value">
                        @if (IsEditingParameter(ParameterField.AnnualExpenses))
                        {
                            <InputNumber @bind-Value="scenario.AnnualExpenses"
                                         class="form-control form-control-sm number-input-no-spinner"
                                         tabindex="3"
                                         @onkeydown="(e) => OnParameterKeyDown(ParameterField.AnnualExpenses, e)" />
                        }
                        else
                        {
                            <span role="button" tabindex="3" class="clickable-value" @onclick="() => StartEditingParameter(ParameterField.AnnualExpenses)">@scenario.AnnualExpenses.ToString("C")</span>
                        }
                    </td>
                    <td class="item-actions">
                        @if (IsEditingParameter(ParameterField.AnnualExpenses))
                        {
                            <button class="btn btn-link text-success p-0 me-2"
                                    @onclick="() => CommitParameterEdit(ParameterField.AnnualExpenses)"
                                    aria-label="Commit annual expenses edit">
                                <i class="bi bi-check-circle"></i>
                            </button>
                            <button class="btn btn-link text-secondary p-0"
                                    @onclick="() => CancelParameterEdit(ParameterField.AnnualExpenses)"
                                    aria-label="Cancel annual expenses edit">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        }
                    </td>
                </tr>
            </tbody>
        </table>

        <h6 class="parameter-subgroup-heading mt-2">Economic</h6>
        <table class="table table-borderless align-middle table-sm compact-table mb-0">
            <tbody>
                <tr class="@(IsEditingParameter(ParameterField.SecuritiesAnnualInterestRate) ? "edit-mode-row" : null)">
                    <td class="item-name">Securities annual interest rate</td>
                    <td class="item-value">
                        @if (IsEditingParameter(ParameterField.SecuritiesAnnualInterestRate))
                        {
                            <InputNumber @bind-Value="scenario.SecuritiesAnnualInterestRate"
                                         class="form-control form-control-sm number-input-no-spinner"
                                         tabindex="4"
                                         @onkeydown="(e) => OnParameterKeyDown(ParameterField.SecuritiesAnnualInterestRate, e)" />
                        }
                        else
                        {
                            <span role="button" tabindex="4" class="clickable-value" @onclick="() => StartEditingParameter(ParameterField.SecuritiesAnnualInterestRate)">@($"{scenario.SecuritiesAnnualInterestRate}%")</span>
                        }
                    </td>
                    <td class="item-actions">
                        @if (IsEditingParameter(ParameterField.SecuritiesAnnualInterestRate))
                        {
                            <button class="btn btn-link text-success p-0 me-2"
                                    @onclick="() => CommitParameterEdit(ParameterField.SecuritiesAnnualInterestRate)"
                                    aria-label="Commit securities annual interest rate edit">
                                <i class="bi bi-check-circle"></i>
                            </button>
                            <button class="btn btn-link text-secondary p-0"
                                    @onclick="() => CancelParameterEdit(ParameterField.SecuritiesAnnualInterestRate)"
                                    aria-label="Cancel securities annual interest rate edit">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        }
                    </td>
                </tr>
                <tr class="@(IsEditingParameter(ParameterField.AnnualInflationRate) ? "edit-mode-row" : null)">
                    <td class="item-name">Annual inflation rate</td>
                    <td class="item-value">
                        @if (IsEditingParameter(ParameterField.AnnualInflationRate))
                        {
                            <InputNumber @bind-Value="scenario.AnnualInflationRate"
                                         class="form-control form-control-sm number-input-no-spinner"
                                         tabindex="5"
                                         @onkeydown="(e) => OnParameterKeyDown(ParameterField.AnnualInflationRate, e)" />
                        }
                        else
                        {
                            <span role="button" tabindex="5" class="clickable-value" @onclick="() => StartEditingParameter(ParameterField.AnnualInflationRate)">@($"{scenario.AnnualInflationRate}%")</span>
                        }
                    </td>
                    <td class="item-actions">
                        @if (IsEditingParameter(ParameterField.AnnualInflationRate))
                        {
                            <button class="btn btn-link text-success p-0 me-2"
                                    @onclick="() => CommitParameterEdit(ParameterField.AnnualInflationRate)"
                                    aria-label="Commit annual inflation rate edit">
                                <i class="bi bi-check-circle"></i>
                            </button>
                            <button class="btn btn-link text-secondary p-0"
                                    @onclick="() => CancelParameterEdit(ParameterField.AnnualInflationRate)"
                                    aria-label="Cancel annual inflation rate edit">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        }
                    </td>
                </tr>
                <tr class="@(IsEditingParameter(ParameterField.BondsAnnualRateOfReturn) ? "edit-mode-row" : null)">
                    <td class="item-name">Bonds annual rate of return</td>
                    <td class="item-value">
                        @if (IsEditingParameter(ParameterField.BondsAnnualRateOfReturn))
                        {
                            <InputNumber @bind-Value="scenario.BondsAnnualRateOfReturn"
                                         class="form-control form-control-sm number-input-no-spinner"
                                         tabindex="6"
                                         @onkeydown="(e) => OnParameterKeyDown(ParameterField.BondsAnnualRateOfReturn, e)" />
                        }
                        else
                        {
                            <span role="button" tabindex="6" class="clickable-value" @onclick="() => StartEditingParameter(ParameterField.BondsAnnualRateOfReturn)">@($"{scenario.BondsAnnualRateOfReturn}%")</span>
                        }
                    </td>
                    <td class="item-actions">
                        @if (IsEditingParameter(ParameterField.BondsAnnualRateOfReturn))
                        {
                            <button class="btn btn-link text-success p-0 me-2"
                                    @onclick="() => CommitParameterEdit(ParameterField.BondsAnnualRateOfReturn)"
                                    aria-label="Commit bonds annual rate of return edit">
                                <i class="bi bi-check-circle"></i>
                            </button>
                            <button class="btn btn-link text-secondary p-0"
                                    @onclick="() => CancelParameterEdit(ParameterField.BondsAnnualRateOfReturn)"
                                    aria-label="Cancel bonds annual rate of return edit">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        }
                    </td>
                </tr>
            </tbody>
        </table>

        <hr />

        <div class="section-heading">
            <h5 class="mb-0">Accounts</h5>
            <button class="btn btn-link p-0 heading-add-button"
                    disabled="@IsSectionBusy(AddItemType.Account)"
                    @onclick="() => StartAdd(AddItemType.Account)"
                    aria-label="Add Account">
                <i class="bi bi-plus-square"></i>
            </button>
        </div>
        <table class="table table-borderless align-middle table-sm compact-table mb-0">
            @if (scenario.Accounts.Count > 0)
            {
                <thead>
                    <tr>
                        <th class="item-name">Name</th>
                        <th class="item-type">Type</th>
                        <th class="item-holdings">Holdings</th>
                        <th class="item-value">Balance</th>
                        <th class="item-actions"></th>
                    </tr>
                </thead>
            }
            <tbody>
                @foreach (var account in scenario.Accounts.OrderBy(a => a.Name, StringComparer.CurrentCultureIgnoreCase))
                {
                    <tr class="@(IsAccountRowEditing(account) ? "edit-mode-row" : null)">
                        <td class="item-name">
                            @if (IsEditingName(account))
                            {
                                <InputText @bind-Value="account.Name"
                                           class="form-control form-control-sm"
                                           @onkeydown="(e) => OnItemNameKeyDown(account, e)" />
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-name" @onclick="() => StartEditingName(account)">@account.Name</span>
                            }
                        </td>
                        <td class="item-type">
                            @if (IsEditingType(account))
                            {
                                <InputSelect @bind-Value="account.Type"
                                             class="form-select form-select-sm"
                                             @onkeydown="(e) => OnAccountTypeKeyDown(account, e)">
                                    @foreach (var typeOption in AccountOptionDisplay.Types)
                                    {
                                        <option value="@typeOption">@typeOption.ToDisplayLabel()</option>
                                    }
                                </InputSelect>
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-value" @onclick="() => StartEditingType(account)">@account.Type.ToDisplayLabel()</span>
                            }
                        </td>
                        <td class="item-holdings">
                            @if (IsEditingHoldings(account))
                            {
                                <InputSelect @bind-Value="account.Holdings"
                                             class="form-select form-select-sm"
                                             @onkeydown="(e) => OnAccountHoldingsKeyDown(account, e)">
                                    @foreach (var holdingsOption in AccountOptionDisplay.Holdings)
                                    {
                                        <option value="@holdingsOption">@holdingsOption.ToDisplayLabel()</option>
                                    }
                                </InputSelect>
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-value" @onclick="() => StartEditingHoldings(account)">@account.Holdings.ToDisplayLabel()</span>
                            }
                        </td>
                        <td class="item-value">
                            @if (IsEditing(account))
                            {
                                <InputNumber @bind-Value="account.Balance"
                                             class="form-control form-control-sm number-input-no-spinner"
                                             @onkeydown="(e) => OnItemValueKeyDown(account, e)" />
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-value" @onclick="() => StartEditing(account)">@account.Balance.ToString("C")</span>
                            }
                        </td>
                        <td class="item-actions">
                            @if (IsAccountRowEditing(account))
                            {
                                <button class="btn btn-link text-success p-0 me-2"
                                        @onclick="() => CommitAccountEdit(account)"
                                        aria-label="Commit account edits for @account.Name">
                                    <i class="bi bi-check-circle"></i>
                                </button>
                                <button class="btn btn-link text-secondary p-0"
                                        @onclick="() => CancelAccountEdit(account)"
                                        aria-label="Cancel account edits for @account.Name">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-link text-danger p-0" @onclick="() => DeleteAccount(account)" aria-label="Delete @account.Name">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }

                @if (activeAddType == AddItemType.Account)
                {
                    <tr class="add-mode-row" id="@GetAddRowId(AddItemType.Account)">
                        <td class="item-name">
                            <InputText id="@GetAddNameInputId(AddItemType.Account)"
                                       @bind-Value="newItemName"
                                       class="form-control form-control-sm"
                                       @onkeydown="OnAddInputKeyDown" />
                        </td>
                        <td class="item-type">
                            <InputSelect @bind-Value="newAccountType"
                                         class="form-select form-select-sm"
                                         @onkeydown="OnAddInputKeyDown">
                                @foreach (var typeOption in AccountOptionDisplay.Types)
                                {
                                    <option value="@typeOption">@typeOption.ToDisplayLabel()</option>
                                }
                            </InputSelect>
                        </td>
                        <td class="item-holdings">
                            <InputSelect @bind-Value="newAccountHoldings"
                                         class="form-select form-select-sm"
                                         @onkeydown="OnAddInputKeyDown">
                                @foreach (var holdingsOption in AccountOptionDisplay.Holdings)
                                {
                                    <option value="@holdingsOption">@holdingsOption.ToDisplayLabel()</option>
                                }
                            </InputSelect>
                        </td>
                        <td class="item-value">
                            <InputNumber @bind-Value="newItemValue"
                                         class="form-control form-control-sm number-input-no-spinner"
                                         @onkeydown="OnAddInputKeyDown" />
                        </td>
                        <td class="item-actions">
                            <button class="btn btn-link text-success p-0 me-2"
                                    @onclick="SaveNewItem"
                                    aria-label="Commit new account">
                                <i class="bi bi-check-circle"></i>
                            </button>
                            <button class="btn btn-link text-secondary p-0"
                                    @onclick="CancelAdd"
                                    aria-label="Cancel new account">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <hr />

        <div class="section-heading">
            <h5 class="mb-0">Income</h5>
            <button class="btn btn-link p-0 heading-add-button"
                    disabled="@IsSectionBusy(AddItemType.Income)"
                    @onclick="() => StartAdd(AddItemType.Income)"
                    aria-label="Add Income">
                <i class="bi bi-plus-square"></i>
            </button>
        </div>
        <table class="table table-borderless align-middle table-sm compact-table mb-0">
            <tbody>
                @foreach (var income in scenario.Income.OrderBy(i => i.Name, StringComparer.CurrentCultureIgnoreCase))
                {
                    <tr class="@(IsIncomeRowEditing(income) ? "edit-mode-row" : null)">
                        <td class="item-name">
                            @if (IsEditingName(income))
                            {
                                <InputText @bind-Value="income.Name"
                                           class="form-control form-control-sm"
                                           @onkeydown="(e) => OnItemNameKeyDown(income, e)" />
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-name" @onclick="() => StartEditingName(income)">@income.Name</span>
                            }
                        </td>
                        <td class="item-value">
                            @if (IsEditing(income))
                            {
                                <InputNumber @bind-Value="income.Amount"
                                             class="form-control form-control-sm number-input-no-spinner"
                                             @onkeydown="(e) => OnItemValueKeyDown(income, e)" />
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-value" @onclick="() => StartEditing(income)">@income.Amount.ToString("C")</span>
                            }
                        </td>
                        <td class="item-actions">
                            @if (IsIncomeRowEditing(income))
                            {
                                <button class="btn btn-link text-success p-0 me-2"
                                        @onclick="() => CommitItemEdit(income)"
                                        aria-label="Commit income edits for @income.Name">
                                    <i class="bi bi-check-circle"></i>
                                </button>
                                <button class="btn btn-link text-secondary p-0"
                                        @onclick="() => CancelItemEdit(income)"
                                        aria-label="Cancel income edits for @income.Name">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-link text-danger p-0" @onclick="() => DeleteIncome(income)" aria-label="Delete @income.Name">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }

                @if (activeAddType == AddItemType.Income)
                {
                    <tr class="add-mode-row" id="@GetAddRowId(AddItemType.Income)">
                        <td class="item-name">
                            <InputText id="@GetAddNameInputId(AddItemType.Income)"
                                       @bind-Value="newItemName"
                                       class="form-control form-control-sm"
                                       @onkeydown="OnAddInputKeyDown" />
                        </td>
                        <td class="item-value">
                            <InputNumber @bind-Value="newItemValue"
                                         class="form-control form-control-sm number-input-no-spinner"
                                         @onkeydown="OnAddInputKeyDown" />
                        </td>
                        <td class="item-actions">
                            <button class="btn btn-link text-success p-0 me-2"
                                    @onclick="SaveNewItem"
                                    aria-label="Commit new income">
                                <i class="bi bi-check-circle"></i>
                            </button>
                            <button class="btn btn-link text-secondary p-0"
                                    @onclick="CancelAdd"
                                    aria-label="Cancel new income">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <hr />

        <div class="section-heading">
            <h5 class="mb-0">Expenses</h5>
            <button class="btn btn-link p-0 heading-add-button"
                    disabled="@IsSectionBusy(AddItemType.Expense)"
                    @onclick="() => StartAdd(AddItemType.Expense)"
                    aria-label="Add Expense">
                <i class="bi bi-plus-square"></i>
            </button>
        </div>
        <div class="expenses-table-wrapper">
        <table class="table table-borderless align-middle table-sm compact-table expenses-table mb-0">
            @if (scenario.Expenses.Count > 0 || activeAddType == AddItemType.Expense)
            {
                <thead>
                    <tr>
                        <th class="item-name">Name</th>
                        <th class="item-value">Start age</th>
                        <th class="item-value">End age</th>
                        <th class="item-value">Amount</th>
                        <th class="item-value">Annual rate of increase</th>
                        <th class="item-actions"></th>
                    </tr>
                </thead>
            }
            <tbody>
                @foreach (var expense in scenario.Expenses.OrderBy(e => e.Name, StringComparer.CurrentCultureIgnoreCase))
                {
                    <tr class="@(IsExpenseRowEditing(expense) ? "edit-mode-row" : null)">
                        <td class="item-name">
                            @if (IsEditingName(expense))
                            {
                                <InputText @bind-Value="expense.Name" class="form-control form-control-sm" @onkeydown="(e) => OnItemNameKeyDown(expense, e)" />
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-name" @onclick="() => StartEditingName(expense)">@expense.Name</span>
                            }
                        </td>
                        <td class="item-value">
                            @if (IsEditingExpenseStartAge(expense))
                            {
                                <InputNumber @bind-Value="expense.AgeStart" class="form-control form-control-sm" @attributes="wholeNumberInputAttributes" @onkeydown="(e) => OnExpenseFieldKeyDown(expense, e)" />
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-value" @onclick="() => StartEditingExpenseStartAge(expense)">@expense.AgeStart</span>
                            }
                        </td>
                        <td class="item-value">
                            @if (IsEditingExpenseEndAge(expense))
                            {
                                <InputNumber @bind-Value="expense.AgeEnd" class="form-control form-control-sm" @attributes="wholeNumberInputAttributes" @onkeydown="(e) => OnExpenseFieldKeyDown(expense, e)" />
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-value" @onclick="() => StartEditingExpenseEndAge(expense)">@expense.AgeEnd</span>
                            }
                        </td>
                        <td class="item-value">
                            @if (IsEditing(expense))
                            {
                                <InputNumber @bind-Value="expense.Amount" class="form-control form-control-sm number-input-no-spinner" @onkeydown="(e) => OnItemValueKeyDown(expense, e)" />
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-value" @onclick="() => StartEditing(expense)">@expense.Amount.ToString("C")</span>
                            }
                        </td>
                        <td class="item-value">
                            @if (IsEditingExpenseAnnualRate(expense))
                            {
                                <div class="expense-rate-edit">
                                    <InputNumber @bind-Value="expense.AnnualRateOfIncrease"
                                                 class="form-control form-control-sm number-input-no-spinner"
                                                 disabled="@expense.UseInflationValue"
                                                 @onkeydown="(e) => OnExpenseFieldKeyDown(expense, e)" />
                                    <label class="form-check-label expense-inflation-toggle">
                                        <input type="checkbox"
                                               class="form-check-input me-1"
                                               checked="@expense.UseInflationValue"
                                               @onchange="(e) => OnExpenseUseInflationChanged(expense, e)" />
                                        Use inflation value
                                    </label>
                                </div>
                            }
                            else
                            {
                                <span role="button" tabindex="0" class="clickable-value" @onclick="() => StartEditingExpenseAnnualRate(expense)">@FormatExpenseAnnualRate(expense)</span>
                            }
                        </td>
                        <td class="item-actions">
                            @if (IsExpenseRowEditing(expense))
                            {
                                <button class="btn btn-link text-success p-0 me-2" @onclick="() => CommitExpenseEdit(expense)" aria-label="Commit expense edits for @expense.Name"><i class="bi bi-check-circle"></i></button>
                                <button class="btn btn-link text-secondary p-0" @onclick="() => CancelExpenseEdit(expense)" aria-label="Cancel expense edits for @expense.Name"><i class="bi bi-x-circle"></i></button>
                            }
                            else
                            {
                                <button class="btn btn-link text-danger p-0" @onclick="() => DeleteExpense(expense)" aria-label="Delete @expense.Name"><i class="bi bi-trash"></i></button>
                            }
                        </td>
                    </tr>
                }

                @if (activeAddType == AddItemType.Expense)
                {
                    <tr class="add-mode-row" id="@GetAddRowId(AddItemType.Expense)">
                        <td class="item-name"><InputText id="@GetAddNameInputId(AddItemType.Expense)" @bind-Value="newItemName" class="form-control form-control-sm" @onkeydown="OnAddInputKeyDown" /></td>
                        <td class="item-value"><InputNumber @bind-Value="newExpenseStartAge" class="form-control form-control-sm" @attributes="wholeNumberInputAttributes" @onkeydown="OnAddInputKeyDown" /></td>
