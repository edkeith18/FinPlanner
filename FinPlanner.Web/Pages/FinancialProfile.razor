    private void SetNewTransferDefaults()
    {
        var orderedAccountNames = scenario.Accounts
            .OrderBy(account => account.Name, StringComparer.CurrentCultureIgnoreCase)
            .Select(account => account.Name)
            .ToList();

        newTransferFromAccountName = orderedAccountNames.FirstOrDefault() ?? string.Empty;
        newTransferToAccountName = orderedAccountNames.Skip(1).FirstOrDefault() ?? newTransferFromAccountName;
    }

    private void EnsureTransferAccountSelectionIsValid(Transfer transfer)
    {
        var orderedAccountNames = scenario.Accounts
            .OrderBy(account => account.Name, StringComparer.CurrentCultureIgnoreCase)
            .Select(account => account.Name)
            .ToList();

        if (orderedAccountNames.Count == 0)
        {
            transfer.FromAccountName = string.Empty;
            transfer.ToAccountName = string.Empty;
            return;
        }

        if (!orderedAccountNames.Contains(transfer.FromAccountName))
        {
            transfer.FromAccountName = orderedAccountNames[0];
        }

        if (!orderedAccountNames.Contains(transfer.ToAccountName))
        {
            transfer.ToAccountName = orderedAccountNames.Skip(1).FirstOrDefault() ?? orderedAccountNames[0];
        }

        if (orderedAccountNames.Count > 1 && transfer.FromAccountName == transfer.ToAccountName)
        {
            transfer.ToAccountName = orderedAccountNames.First(accountName => accountName != transfer.FromAccountName);
        }
    }

