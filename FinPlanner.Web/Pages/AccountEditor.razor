@page "/account/new"
@page "/account/{name}"

@using FinPlanner.Engine
@using Microsoft.AspNetCore.Components

@inject Portfolio portfolio
@inject NavigationManager Nav

<h3>@(IsNew ? "Create Account" : "Account Details")</h3>

@if (account is null)
{
    <p>Account not found.</p>
}
else
{
    <div class="card p-3" style="max-width: 400px;">
        <div class="mb-3">
            <label class="form-label">Name</label>
            <InputText @bind-Value="account.Name" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Balance</label>
            <InputNumber @bind-Value="account.Balance" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Type</label>
            <InputSelect @bind-Value="account.Type" class="form-select">
                @foreach (var typeOption in AccountOptionDisplay.Types)
                {
                    <option value="@typeOption">@typeOption.ToDisplayLabel()</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label class="form-label">Holdings</label>
            <InputSelect @bind-Value="account.Holdings" class="form-select">
                @foreach (var holdingsOption in AccountOptionDisplay.Holdings)
                {
                    <option value="@holdingsOption">@holdingsOption.ToDisplayLabel()</option>
                }
            </InputSelect>
        </div>

        <button class="btn btn-primary" @onclick="Save">
            @(IsNew ? "Create" : "Save")
        </button>

        <button class="btn btn-secondary ms-2" @onclick="Back">
            Back
        </button>
    </div>
}

@code {
    [Parameter] public string? Name { get; set; }

    private Account? account;
    private bool IsNew => Name is null;

    protected override void OnParametersSet()
    {
        if (IsNew)
        {
            account = new Account { Name = "", Balance = 0, Type = AccountType.Brokerage, Holdings = AccountHoldings.Equities };
        }
        else
        {
            account = portfolio.Accounts.FirstOrDefault(a => a.Name == Name);
        }
    }

    private void Save()
    {
        if (account is null)
            return;

        if (IsNew)
        {
            portfolio.AddAccount(account.Name, account.Balance, account.Type, account.Holdings);
        }

        Nav.NavigateTo("financial-profile");
    }

    private void Back()
    {
        Nav.NavigateTo("financial-profile");
    }
}
