@using FinPlanner.Engine
@implements IDisposable
@inject Scenario scenario
@inject MaximumExpenseCalculator maximumExpenseCalculator

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">FinPlanner</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <div class="nav-shell">
        <nav class="nav d-flex flex-column">
            <div class="nav-item px-3 ">
                <NavLink class="nav-link" href="financial-scenario">
                    <span class="bi bi-clipboard2-data-fill-nav-menu" aria-hidden="true"></span> Financial Scenario
                </NavLink>
            </div>
            <div class="nav-item px-3 ">
                <NavLink class="nav-link" href="financial-plan">
                    <span class="bi bi-rocket-takeoff-nav-menu" aria-hidden="true"></span> Financial Plan
                </NavLink>
            </div>
        </nav>

        <div class="nav-footer">
            <section class="quick-plan-panel" aria-label="Quick plan">
                <h3 class="quick-plan-title">Quick plan</h3>
                <p class="quick-plan-label">Maximum annual expenses</p>
                <p class="quick-plan-label-detail">(for $0 at end of plan)</p>
                <p class="quick-plan-value">@MaximumAnnualExpensesDisplay</p>
            </section>

            <div class="build-version-text">
                <p>@BuildVersioningInfo.Version</p>
                <p>@BuildVersioningInfo.Branch</p>
            </div>
        </div>
    </div>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private string MaximumAnnualExpensesDisplay => maximumExpenseCalculator.TryCalculate(scenario, out var maximumAnnualExpenses)
        ? maximumAnnualExpenses.ToString("C")
        : "Plan fails";

    protected override void OnInitialized()
    {
        scenario.Changed += OnScenarioChanged;
    }

    private void OnScenarioChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    public void Dispose()
    {
        scenario.Changed -= OnScenarioChanged;
    }
}
